<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- File name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/label_file_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_file_name"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_file_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/value_unknown" />
        </LinearLayout>

        <!-- File size -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">
            <TextView
                android:id="@+id/label_file_size"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_file_size"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_file_size"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/value_unknown" />
        </LinearLayout>

        <!-- Architecture -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">
            <TextView
                android:id="@+id/label_architecture"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_architecture"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_architecture"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/value_unknown" />
        </LinearLayout>

        <!-- Endianness -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">
            <TextView
                android:id="@+id/label_endianness"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_endianness"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_endianness"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/value_unknown" />
        </LinearLayout>

        <!-- Entry point -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">
            <TextView
                android:id="@+id/label_entry_point"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_entry_point"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_entry_point"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:fontFamily="monospace"
                android:text="@string/value_unknown" />
        </LinearLayout>

        <!-- Project name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">
            <TextView
                android:id="@+id/label_project_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_project_name"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_project_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/value_unknown" />
        </LinearLayout>

        <!-- Open Decompiler button -->
        <Button
            android:id="@+id/button_open_decompiler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/button_open_decompiler" />

    </LinearLayout>
</ScrollView>
